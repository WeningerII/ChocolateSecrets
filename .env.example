# VITE_USDA_FDC_API_KEY: Optional. Required only if Tony enables live
# USDA FoodData Central queries for ingredient nutritional lookups.
# Falls back to the bundled snapshot when absent.
VITE_USDA_FDC_API_KEY=""

# RESEND_API_KEY: Required for sending emails via Resend.
RESEND_API_KEY=""

# CHEF_EMAIL: The email address to send the shopping list to.
CHEF_EMAIL=""

# TWILIO_ACCOUNT_SID: Required for sending SMS via Twilio.
TWILIO_ACCOUNT_SID=""

# TWILIO_AUTH_TOKEN: Required for sending SMS via Twilio.
TWILIO_AUTH_TOKEN=""

# TWILIO_PHONE_NUMBER: The Twilio phone number to send SMS from.
TWILIO_PHONE_NUMBER=""

# CHEF_PHONE_NUMBER: The phone number to send the shopping list to.
CHEF_PHONE_NUMBER=""

# VITE_FIREBASE_APPCHECK_SITE_KEY: Optional. The reCAPTCHA v3 site key for Firebase
# App Check (Firebase console -> App Check -> register the web app). When set, the
# client attaches App Check tokens to Firestore/Functions calls. Leave empty to keep
# App Check off (the app runs identically). See docs/security-hardening.md.
VITE_FIREBASE_APPCHECK_SITE_KEY=""

# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN: Optional, DEVELOPMENT ONLY. A debug token from
# the Firebase console so App Check passes on localhost/CI. Never set in production.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=""
