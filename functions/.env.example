# Cloud Functions configuration for the sendShoppingList callable (ADR-0006).
# Copy to functions/.env to bind the NON-SECRET string params at deploy time
# (the Firebase CLI reads functions/.env when deploying; it also prompts for
# any param left unset). Names only — never put real values in this example.
#
# --- Secrets (Secret Manager — NOT this file) ---
# Credentials are defineSecret() params and must be set with the CLI, never
# committed or placed in functions/.env:
#   firebase functions:secrets:set RESEND_API_KEY
#   firebase functions:secrets:set TWILIO_ACCOUNT_SID
#   firebase functions:secrets:set TWILIO_AUTH_TOKEN
#
# --- Non-secret params (this file) ---

# RESEND_FROM: Verified Resend sender, e.g. "Chocolate Secrets <lists@yourdomain.com>".
# Empty = email channel unconfigured (no onboarding@resend.dev fallback — ADR-0006).
RESEND_FROM=""

# CHEF_EMAIL: Destination email address for shopping lists.
CHEF_EMAIL=""

# TWILIO_PHONE_NUMBER: Twilio sender phone number (E.164).
TWILIO_PHONE_NUMBER=""

# CHEF_PHONE_NUMBER: Destination SMS phone number (E.164).
CHEF_PHONE_NUMBER=""
