{
  "name": "chocolate-secrets-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "migrate:i18n": "node scripts/migrate-localized-strings.mjs",
    "migrate:cross-contact": "node scripts/migrate-cross-contact-risks.mjs",
    "test": "vitest run --exclude 'functions/lib/**' --exclude '**/*.smoke.test.ts'",
    "test:rules": "vitest run -c vitest.config.rules.ts",
    "test:e2e": "playwright test",
    "check:schema": "node scripts/check-schema-drift.mjs",
    "check:locale-parity": "node scripts/check-locale-parity.mjs",
    "check:hardcoded-strings": "node scripts/check-hardcoded-strings.mjs",
    "check:functions-secrets": "node scripts/check-functions-secrets.mjs",
    "seed:expense-categories": "node scripts/seed-expense-categories.mjs",
    "test:functions": "npm --prefix functions run test",
    "start": "node server.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@phosphor-icons/react": "^2.1.7",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-big-calendar": "^1.16.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.7",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.1",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "rrule": "^2.8.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "firebase-admin": "^13.8.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
